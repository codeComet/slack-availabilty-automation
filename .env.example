# Slack app credentials (from api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_CLIENT_ID=...
SLACK_CLIENT_SECRET=...

# Supabase (existing "slack-availability" project)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...

# Slack workspace (team) ID — the T... value from your workspace URL or slash command payload
SLACK_TEAM_ID=T...

# Slack channel ID for #availability (right-click channel → Copy link → extract C... from URL)
SLACK_AVAILABILITY_CHANNEL_ID=C...

# Public URL of this deployment (used for OAuth redirect)
APP_URL=https://<your-vercel-domain>.vercel.app

# Google Calendar integration (from console.cloud.google.com → APIs & Services → Credentials)
# Authorised redirect URI to add: https://<your-vercel-domain>.vercel.app/api/google/oauth/callback
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
